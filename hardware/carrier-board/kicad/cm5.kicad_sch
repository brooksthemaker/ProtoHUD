  (text "CM5 — compute module; drives ONLY HUB75 (+ CSI / HDMI / USB host)" (at 25.4 31.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 81f6016b-78b7-4d5f-a397-bdfc1d0b7aba))
  (text "Parts: 2x Hirose DF40C-100DS-0.4V(51), decoupling per CM5 guide," (at 25.4 34.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 6e62a377-abfd-4c93-b873-61a22d938f69))
  (text "  nRPIBOOT jumper + USB (eMMC flash), spare-GPIO debug header." (at 25.4 37.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 099702cc-ef2b-4a23-8f95-2e5cbff4f421))
  (text "Nets: HUB75 BCM 4-27 (see PINMAP.md) -> face_buffer; +5V, +3V3, GND." (at 25.4 40.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 085f00cb-36b4-4476-96f9-53845444f7d5))
  (text "Non-HUB75 CM5 lines: BCM7=RP_RUN, BCM8=RP_BOOTSEL (RP2354B control)," (at 25.4 43.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 080728e3-2846-4912-a55c-2d031312cb27))
  (text "  BCM18/BCM19 = fan zone 1/2 (low-side MOSFET gates, sys::FanController)." (at 25.4 46.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 995629db-bc05-43ad-a75d-2f62f0fc6feb))
  (text "All other peripheral I/O lives on the RP2354B, not here." (at 25.4 49.40 0) (effects (font (size 1.5 1.5)) (justify left bottom)) (uuid 6b24781d-919b-4817-ac11-656f60392e63))
