# Build output
build/
*.o
*.a
*.d

# Shared libraries — excluded globally, but the vendored VITURE SDK
# binaries below are intentionally tracked (they are pre-built aarch64
# binaries that have no other install source).
*.so
!vendor/viture/lib/**/*.so

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
_deps/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# macOS
.DS_Store

# Large vendored binaries are tracked intentionally (vendor/viture/lib/)
# If you want to exclude them, uncomment the lines below:
# vendor/viture/lib/

# Compiled device tree blobs (regenerated by install.sh)
overlays/*.dtbo

# Convenience symlink created by install.sh
/protohud

# Claude local config
.claude/

# Runtime config — written by the app on exit with live settings.
# config/config.example.json is the tracked defaults reference.
config/config.json
# Other app-written runtime state beside it (atomic-save temp file, persisted
# notification log, native-face state, saved profiles, QR captures).
config/.config.json
config/protohud_notifications.json
config/protoface_state.json
config/profiles/
config/qr_codes/

# Updater runtime state — rollback marker + config backups written by
# scripts/update.sh (see scripts/rollback.sh). Never committed.
state/

# Python bytecode (version/arch-specific — never commit).
__pycache__/
*.pyc

# Scheduler daemon — secrets and runtime artifacts (never commit OAuth creds).
scheduler_daemon/client_secret.json
scheduler_daemon/token.json
scheduler_daemon/config.json
scheduler_daemon/__pycache__/
scheduler_daemon/*.events.json
scheduler_daemon/events.json
scheduler_daemon/scheduler_status.json
scheduler_daemon/manual_events.json
