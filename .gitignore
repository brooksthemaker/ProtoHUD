# Build output
build/
*.o
*.a
*.d

# Shared libraries — excluded globally, but the vendored VITURE SDK
# binaries below are intentionally tracked (they are pre-built aarch64
# binaries that have no other install source).
*.so
!vendor/viture/lib/**/*.so

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
compile_commands.json
_deps/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# macOS
.DS_Store

# Large vendored binaries are tracked intentionally (vendor/viture/lib/)
# If you want to exclude them, uncomment the lines below:
# vendor/viture/lib/

# Compiled device tree blobs (regenerated by install.sh)
overlays/*.dtbo

# Convenience symlink created by install.sh
/protohud

# Claude local config
.claude/
